# GENERATED by scripts/sim/capture-deck-baseline.sh — do not hand-edit.
#
# The REAL Deck's userspace, captured off the device. docker/steamos.Dockerfile pins to this
# so the sim builds against the Deck's glibc/gcc/libsystemd rather than archlinux:latest,
# which drifts ahead of SteamOS and quietly answers a different question.
#
# RE-RUN THIS AFTER EVERY SteamOS UPDATE. The git diff of this file is the upgrade note:
# it names exactly what moved under the launcher, and a changed GLIBC/GCC is a reason to
# re-run 'just sim all' before trusting any prior green.
#
# It records ONE unit. Every hardware result in this project so far is from the OLED
# (durable/hardware.md); an LCD baseline would legitimately differ and is not captured here.
#
# Coverage is unchanged by this file: no GPU, no VA-API, no gamescope, no battery, no ACPI
# in a container, ever. scripts/sim/run.sh still refuses those gates with exit 6.
OS_ID=steamos
OS_NAME=SteamOS
OS_VERSION_ID=3.8.15
OS_BUILD_ID=20260715.1
OS_VARIANT_ID=steamdeck
KERNEL=6.16.12-valve24.5-1-neptune-616-gb2f7cfe85e45
ARCH=x86_64
BOARD=Galileo
BOARD_VERSION=1
GLIBC=2.41
GCC=
PKG_GLIBC=2.41+r65+ge7c419a29575-1
PKG_GCC_LIBS=15.1.1+r7+gf36ec88aa85a-1
PKG_SYSTEMD_LIBS=257.7-2.5
PKG_CURL=8.15.0-1
PKG_LIBPULSE=17.0+r43+g3e2bb8a1e-1
PKG_LIBXCB=1.17.0-1
PKG_LIBEVDEV=1.13.4-1
PKG_FLATPAK=1:1.16.6-1.1
PKG_BUBBLEWRAP=0.11.0-1
PKG_MESA=25.3.0.213835.radeonsi_25.3.0-4.1


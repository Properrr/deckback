# Copy to .env and edit. Sourced by the justfile and scripts/lib.sh. .env is gitignored.

# Container engine: docker or podman. Scripts only assume a docker-compatible CLI.
CONTAINER_ENGINE=docker

# gclient ROOT for the Cobalt/Chrobalt checkout, bind-mounted at /src. The engine tree lands one
# level down at $COBALT_SRC/src (Chrobalt uses a gclient solution named `src`).
COBALT_SRC=./cobalt

# Deck deploy target for `just deploy/run/logs/debug` is configured in the gitignored
# `.steamdeck_auth` file (STEAMDECK_USER / STEAMDECK_IP / STEAMDECK_PORT / optional password).
# Override here only if you need to force a different host:
# DECK_HOST=deck@192.168.1.42

# docker-compose defaults the container UID/GID to 1000. Do NOT set UID here — it is a readonly
# bash variable and sourcing .env would error. If your host account is not 1000, adjust the compose
# build args instead.

# COBALT_COMMIT is NOT set here — the scripts source it from DEPS.pin so source and build-deps can
# never drift.

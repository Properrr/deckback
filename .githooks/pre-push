#!/usr/bin/env bash
# Pre-push hook: run the SAME gate CI runs, so a push never lands red. It delegates to
# scripts/preflight.sh — the one definition shared with .github/workflows/lint.yml — which runs the
# harness suite, clang-format-18, the launcher gcc/clang builds, the gn-args check and shellcheck,
# bootstrapping pinned clang-format-18/shellcheck into a cached venv if the system lacks them.
#
# This replaces the old hook that mirrored only clang-format + shellcheck: it let a stale test and a
# clang-only -Werror land red because it never ran the harness suite or the launcher builds locally.
#
# Enable once per clone:  just hooks   (sets core.hooksPath to .githooks)
# Bypass a single push (use sparingly, CI is still the backstop):  git push --no-verify
set -uo pipefail
cd "$(git rev-parse --show-toplevel)" || exit 1

if ./scripts/preflight.sh all; then
  echo "pre-push: preflight green ✓ — safe to push."
  exit 0
fi
echo "pre-push: BLOCKED — preflight failed above; this would land red in CI." >&2
echo "          Fix it (formatting: 'just fmt'), commit, and push again." >&2
echo "          Bypass once with 'git push --no-verify' (CI still gates)." >&2
exit 1
